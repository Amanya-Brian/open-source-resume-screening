# Application Settings
APP_NAME=Resume Screening System
DEBUG=false

# TalentMatch API
TALENTMATCH_API_URL=http://localhost:5000
TALENTMATCH_API_TIMEOUT=30

# MongoDB
MONGODB_URI=mongodb+srv://eumubyey_db_user:KfAeDLBcyjQcdg00@resume.iwhgoj1.mongodb.net/
MONGODB_DATABASE=resume_screening

# Flask API
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=false

# Ollama LLM Settings (Local - Recommended)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# Legacy LLM Settings (Hugging Face - fallback)
LLM_MODEL_NAME=meta-llama/Llama-2-7b-chat-hf
LLM_DEVICE=auto
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3
LLM_USE_8BIT=true

# Embedding Service
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=16
EMBEDDING_CACHE_ENABLED=true

# Screening Settings
SCREENING_MIN_SCORE_THRESHOLD=0.5
SCREENING_TOP_K=10

# Ranking Weights (must sum to 1.0)
WEIGHT_SKILLS_MATCH=0.35
WEIGHT_EXPERIENCE=0.20
WEIGHT_EDUCATION=0.15
WEIGHT_PROJECTS=0.15
WEIGHT_CERTIFICATIONS=0.10
WEIGHT_SOFT_SKILLS=0.05

# Fairness Settings
FAIRNESS_DIR_THRESHOLD=0.8
FAIRNESS_VARIANCE_THRESHOLD=0.001

# Validation Settings
VALIDATION_AGREEMENT_THRESHOLD=0.90

# Performance Settings
MAX_CONCURRENT_CANDIDATES=4
PIPELINE_TIMEOUT_SECONDS=1800
BATCH_SIZE=50

# Experiment Tracking (optional)
# MLFLOW_TRACKING_URI=http://localhost:5001
# MLFLOW_EXPERIMENT_NAME=resume-screening
# WANDB_PROJECT=resume-screening
# WANDB_ENABLED=false

# Logging
LOG_LEVEL=INFO
